{
  "name": "AliExpress Global Switcher",
  "manifest_version": 3,
  "version": "3.0.0",
  "description": "Automatically redirects regional AliExpress domains to the global version with correct locale, currency, and region settings",
  "permissions": [
    "tabs",
    "storage",
    "cookies",
    "webNavigation"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "*://*.aliexpress.com/*",
    "*://*.aliexpress.ru/*",
    "*://*.aliexpress.us/*"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  }
}